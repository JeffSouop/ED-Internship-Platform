# Copier vers .env sur le serveur (avec docker-compose.dist.yml renommé en docker-compose.yml ou -f)

# ——— Images GHCR (voir Packages sur GitHub) ———
# Propriétaire du dépôt en minuscules, ex. ghcr.io/audreyjordansouop
ED_IMAGE_REGISTRY=ghcr.io/talent-tally
ED_IMAGE_TAG=latest

# ——— Ports ———
HTTP_PORT=8080
API_PORT=4000
POSTGRES_PORT=5433

# ——— Postgres ———
POSTGRES_DB=ducasse_careers
POSTGRES_USER=ducasse
POSTGRES_PASSWORD=changez-moi

# ——— API ———
ADMIN_JWT_SECRET=changez-moi-long-et-aleatoire
FRONTEND_ORIGIN=https://votre-domaine.fr
APP_PUBLIC_URL=https://votre-domaine.fr
FORM_ACCESS_PASSWORD=ducasse2026

# Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Internship & Career Department

# DocuSign (fichier monté : secrets/docusign_private.key)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_TEMPLATE_ID=
DOCUSIGN_OAUTH_HOST=account.docusign.com
DOCUSIGN_RESTAPI_BASE_URI=https://eu.docusign.net/restapi
DOCUSIGN_SEND_MODE=template
DOCUSIGN_ROLE_STUDENT=Etudiant / Student
DOCUSIGN_ROLE_COMPANY=Représentant de l'entreprise / Company Representative

# Optionnel
# DOCUSIGN_KEY_PATH=./secrets/docusign_private.key
# COMPANY_FORM_URL=https://votre-domaine.fr/company
