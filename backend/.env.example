PORT=4000
DATABASE_URL=postgresql://ducasse:ducasse_local_dev@localhost:5433/ducasse_careers
ADMIN_PASSWORD=ducasse2026
ADMIN_JWT_SECRET=change-me-in-production
# Une ou plusieurs origines du front (séparées par des virgules), ex. Vite ou Docker sur 8080
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8080
# Optionnel — modèle Word (défaut : templates/Modele2025ConventiondestageFPADv0.11.docx à la racine du projet)
# CONVENTION_TEMPLATE_PATH=/chemin/vers/modele.docx
# CONVENTION_OUTPUT_DIR=/chemin/vers/convention

# DocuSign — production (voir Documents/DocuSign/Signature/template_signature_prod.py)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_TEMPLATE_ID=
DOCUSIGN_OAUTH_HOST=account.docusign.com
DOCUSIGN_RESTAPI_BASE_URI=https://eu.docusign.net/restapi
# Défaut : private.key à la racine du projet (copie locale de la clé DocuSign)
DOCUSIGN_PRIVATE_KEY_PATH=private.key
# template = convention .docx générée + emplacements signature du modèle DocuSign (recommandé)
# document = .docx seul avec positions codées en dur (secours)
DOCUSIGN_SEND_MODE=template
DOCUSIGN_ROLE_STUDENT=Etudiant / Student
DOCUSIGN_ROLE_COMPANY=Représentant de l'entreprise / Company Representative
