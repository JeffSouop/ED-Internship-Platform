# Interface utilisateur : nginx (:80) + TanStack SSR via Wrangler sur 127.0.0.1:8787 dans le même conteneur.
# Même logique métier qu’avant, mais un seul service Compose « ui » (proche d’un front + reverse-proxy embarqué).

FROM node:22-bookworm-slim AS build

# Injectées au build (docker compose build.args) — alignées sur backend/.env / .env racine
ARG VITE_FORM_ACCESS_PASSWORD=ducasse2026
ARG VITE_API_URL=
ENV VITE_FORM_ACCESS_PASSWORD=$VITE_FORM_ACCESS_PASSWORD
ENV VITE_API_URL=$VITE_API_URL

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG NODE_MAX_OLD_SPACE_SIZE=4096
ENV NODE_OPTIONS="--max-old-space-size=${NODE_MAX_OLD_SPACE_SIZE}"
ENV NODE_ENV=production
RUN apt-get update && apt-get install -y --no-install-recommends util-linux \
  && rm -rf /var/lib/apt/lists/* \
  && (dd if=/dev/zero of=/swapfile bs=1M count=2048 status=none \
      && chmod 600 /swapfile && mkswap /swapfile && swapon /swapfile || true) \
  && npm run build \
  && test -f dist/server/wrangler.json \
  && test -d dist/client/assets \
  && (swapoff /swapfile 2>/dev/null || true) \
  && rm -f /swapfile

FROM node:22-bookworm-slim

WORKDIR /app
ENV NODE_ENV=production
ENV HOME=/tmp
ENV WRANGLER_SEND_METRICS=false

ARG TARGETARCH

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates nginx curl \
  && rm -rf /var/lib/apt/lists/* \
  && rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true

COPY package.json package-lock.json ./
RUN ARCH="${TARGETARCH:-}" \
  && if [ -z "$ARCH" ]; then \
       case "$(uname -m)" in x86_64) ARCH=amd64 ;; aarch64) ARCH=arm64 ;; *) echo "Arch $(uname -m) non supportée" && exit 1 ;; esac; \
     fi \
  && npm ci --omit=dev \
  && npm install wrangler@4 --no-audit --no-fund \
  && case "$ARCH" in \
       amd64) npm install @cloudflare/workerd-linux-64 --no-audit --no-fund ;; \
       arm64) npm install @cloudflare/workerd-linux-arm64 --no-audit --no-fund ;; \
       *) echo "Plateforme non supportée: $ARCH" && exit 1 ;; \
     esac \
  && (test -x node_modules/@cloudflare/workerd-linux-arm64/bin/workerd \
      || test -x node_modules/@cloudflare/workerd-linux-64/bin/workerd \
      || (echo "workerd binaire introuvable" && ls -la node_modules/@cloudflare/ && exit 1))

COPY --from=build /app/dist ./dist
RUN test -f dist/server/wrangler.json && test -d dist/client/assets \
  || (echo "ERREUR: build UI incomplet (dist/server manquant). Rebuild sans cache: docker compose build --no-cache ui" >&2 && exit 1)
COPY wrangler.jsonc ./wrangler.jsonc

COPY docker/nginx/ui.conf /etc/nginx/conf.d/default.conf
COPY docker/entrypoint-ui.sh /entrypoint-ui.sh
RUN chmod +x /entrypoint-ui.sh

EXPOSE 80

ENTRYPOINT ["/entrypoint-ui.sh"]
